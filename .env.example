# Database Configuration
POSTGRES_DB=northstar
POSTGRES_USER=northstar
# REQUIRED: set a strong password — no default is provided in docker-compose.yml
POSTGRES_PASSWORD=

# Application Ports
API_PORT=3000
WEB_PORT=8080

# Books Library Path (absolute path on your host machine)
# Example: /home/username/Books or /mnt/nas/Books
BOOKS_LIBRARY_PATH=./books

# REQUIRED in production: generate with `openssl rand -base64 64`
# The server refuses to start in production without this value set and
# non-default. Never commit the actual secret to version control.
JWT_SECRET=

# Access-token lifetime (renewed automatically via refresh tokens below).
# JWT_EXPIRES_IN=24h
# Refresh-token lifetime in days. A rotating, server-stored refresh token lets
# the short access token renew instead of the session hard-expiring.
# JWT_REFRESH_EXPIRES_IN_DAYS=30

# Password reset (self-service, no email provider required). The reset link is
# always written to the server logs. For headless/no-email setups, optionally
# return the link in the API response. APP_BASE_URL builds the link.
# PASSWORD_RESET_TTL_MINUTES=60
# PASSWORD_RESET_RETURN_LINK=false
# APP_BASE_URL=http://localhost:5173

# In-book full-text search: cap the extracted text stored/indexed per book
# (keeps the generated tsvector within Postgres limits).
# FULLTEXT_MAX_CHARS=600000

# Restrict CORS to your frontend origin (comma-separated for multiple).
# Leave empty to reflect the request origin (suitable for same-origin setups).
# Example: https://books.example.com
CORS_ORIGIN=

# Metadata API Keys (optional but recommended for better metadata)
GOOGLE_BOOKS_API_KEY=

# VITE_API_URL is a build-time variable only and is NOT used at runtime —
# the web app calls /api/... which nginx proxies to the api service.
# Set this only if you build the web image outside of docker-compose.
# VITE_API_URL=http://localhost:3000
